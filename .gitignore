.env
.env.*
.dev.env
*.env.local
node_modules/

# Exclude markdown files by default (design notes, architecture
# docs, battle reports, CLAUDE.md, READMEs). Published docs ship
# as HTML under landing/docs/.
*.md

# Re-include: user-feedback corpus (Kibana + Elasticsearch theme
# write-ups that drive XERJ design decisions). These are the
# research artifacts we want in the repo.
!user-feedback/**/*.md

# Re-include: internal design/planning docs we want in the repo.
!playground/docs/**/*.md

# Re-include: engine working notes for future Claude sessions
# (session log in git form — motivations, benchmark results,
# architecture decisions).
!engine/CLAUDE.md
!engine/README.md
!engine/ARCHITECTURE_*.md
!engine/BATTLE_*.md
!engine/REAL_BATTLE_*.md
!engine/SEARCH_BATTLE_*.md
!engine/STORAGE_BATTLE_*.md
!engine/CHAOS_*.md
!engine/CAPPED_*.md
!engine/CLUSTER_*.md
!engine/COMPRESSION_*.md
!engine/CLUSTERING_*.md
!engine/ES_vs_*.md

# Re-include: engine/reports/ for datetime-stamped test/bench logs
!engine/reports/**

# Re-include: engine/docs/ for design notes (API specs, RFCs).
!engine/docs/**/*.md

# Re-include: sales-engineer demo kit (runbook, pitch, objection bank).
!demo/**/*.md

# Rust build output
target/

# Upstream Elasticsearch reference clone — not part of this repo
es-reference/

# Local tool state + deploy artifacts
.claude/
encrypted/
.DS_Store

# Ephemeral runtime / demo state (regenerated by demo + CLI scripts)
demo/.cli-validate/
demo/.flow-data/
demo/.ingest-validate/
demo/.flow-chrome/
demo/.xerj.log
demo/.xerj.pid
engine/demo-data/
!engine/IMPLEMENTATION_*.md
scratchpad/
engine/build.log

# ----------------------------------------------------------------------
# OSS release hygiene (added by RELEASE_HYGIENE_AUDIT). Additive only —
# NOTE: ignoring a path does not untrack files already committed. To stop
# shipping the internal dirs below, maintainers must also run:
#   git rm -r --cached brief landing/resources/xerj-sales-kit.zip
# (xerj-ux/ is intentionally tracked — the Console UI ships with the
#  open-source engine so the binary bundles a working console.)
# ----------------------------------------------------------------------

# Local Cloudflare Wrangler state (may contain account/session data).
.wrangler/

# Internal go-to-market material — not part of the OSS engine.
# (Recommended for a separate repo; see docs/RELEASE_HYGIENE_AUDIT.md.)
brief/
landing/resources/xerj-sales-kit.zip

# Re-include root OSS scaffolding so the default *.md / no-extension
# ignore above does not swallow the standard public-repo files.
!README.md
!LICENSE
!LICENSE.md
!NOTICE
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!SECURITY.md
!CHANGELOG.md

# Re-include the public architecture doc (Markdown is ignored by default above).
!docs/ARCHITECTURE.md
!ROADMAP.md
!docs/**/*.md

# Transient demo-capture artifacts (local paths + ephemeral tokens)
demo/screenshots/manifest.json
demo/.flow-data/
demo/.flow-chrome/
